---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const experiences = await getCollection('experiences');
---

<Layout>
	<div class="max-w-7xl mx-auto px-4 py-12">
		<h1 class="text-4xl font-bold mb-8 tracking-tight">Work</h1>
		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			{experiences.map((experience) => (
				<a href={`/experience/${experience.slug}`} class="group block border border-border rounded-lg overflow-hidden hover:border-primary transition-colors bg-card">
					<div class="aspect-video bg-muted relative">
                        {/* Image would go here */}
                    </div>
                    <div class="p-6">
					    <h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{project.data.title}</h2>
                        <p class="text-muted-foreground line-clamp-2">{project.data.description}</p>
                    </div>
				</a>
			))}
            {projects.length === 0 && (
                <div class="col-span-full py-12 text-center border rounded-lg border-dashed text-muted-foreground">
                    <p>No projects added yet.</p>
                </div>
            )}
		</div>
	</div>
</Layout>
