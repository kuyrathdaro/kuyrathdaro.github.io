---
import { ClientRouter } from 'astro:transitions';
import { Navbar } from '../components/common/Navbar';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Rathdaro Kuy</title>
        <ClientRouter />
	</head>
	<body class="bg-white text-foreground min-h-screen font-sans antialiased transition-colors duration-300 relative overflow-x-hidden">
        {/* Soft, Soothing Background Liquid Orbs */}
        <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
            <div class="absolute -top-[20%] -left-[10%] w-[70vw] h-[70vh] rounded-full bg-[#F5F5F7]/80 mix-blend-multiply filter blur-[120px] opacity-60"></div>
            <div class="absolute top-[10%] -right-[10%] w-[60vw] h-[60vh] rounded-full bg-[#F5F5F7]/60 mix-blend-multiply filter blur-[120px] opacity-50"></div>
            <div class="absolute -bottom-[20%] left-[20%] w-[80vw] h-[80vh] rounded-full bg-[#F5F5F7]/80 mix-blend-multiply filter blur-[120px] opacity-60"></div>
        </div>

        <div class="relative z-10">
            <Navbar client:load />
            <main class="pt-8">
                <slot />
            </main>

            <footer class="py-12 px-4 border-t border-border/40 bg-background/30 backdrop-blur-sm relative z-10">
                <div class="max-w-7xl mx-auto flex flex-col items-center gap-2 text-center">
                    <p class="text-[11px] uppercase tracking-widest text-muted-foreground/50 font-bold flex items-center justify-center gap-2">
                        &copy; {new Date().getFullYear()}
                        <span class="opacity-30">•</span> 
                        Created with <span class="text-primary tracking-normal">❤️</span> using <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors duration-300">Astro</a>
                    </p>
                </div>
            </footer>
        </div>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
